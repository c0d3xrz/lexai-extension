{
  "manifest_version": 3,
  "name": "LexAI - Tradutor Inteligente",
  "short_name": "LexAI",
  "version": "1.0.0",
  "description": "Tradução e explicação instantânea de textos selecionados em PDFs e páginas web. Sem cadastro, sem configuração.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tts"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/*", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.svg",
      "128": "icons/icon128.svg"
    }
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.svg",
    "128": "icons/icon128.svg"
  }
}
